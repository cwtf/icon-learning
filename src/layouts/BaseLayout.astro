---
import "@fontsource-variable/inter/index.css";
import "../styles/global.css";
import Nav from "../components/layout/Nav.astro";
import Footer from "../components/layout/Footer.astro";
import { site } from "../content/site";
import ogImage from "../../assets/source/brand/logo/icon-learning-black.png";

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  image?: string;
  imageAlt?: string;
}

const pageTitle = Astro.props.title ?? site.title;
const pageDescription = Astro.props.description ?? site.description;
const lang = Astro.props.lang ?? "en-MY";
const canonical = new URL(Astro.url.pathname, site.url);
const metaImage = new URL(Astro.props.image ?? ogImage.src, site.url);
const metaImageAlt = Astro.props.imageAlt ?? `${site.name} logo`;
const globalStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: site.name,
    legalName: site.legalName,
    url: site.url,
    logo: metaImage.toString(),
    email: site.email,
    telephone: site.phone,
    contactPoint: [
      {
        "@type": "ContactPoint",
        telephone: site.phone,
        email: site.email,
        contactType: "training inquiry",
        areaServed: "MY",
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    potentialAction: {
      "@type": "SearchAction",
      target: `${site.url}/programs?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#fbfaf8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#121110" media="(prefers-color-scheme: dark)" />
    <script is:inline>
      try {
        var storedTheme = localStorage.getItem("theme");
        if (storedTheme === "light" || storedTheme === "dark") {
          document.documentElement.dataset.theme = storedTheme;
        }
      } catch (e) {}
    </script>
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={metaImage} />
    <meta property="og:image:alt" content={metaImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={metaImage} />
    <meta name="twitter:image:alt" content={metaImageAlt} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(globalStructuredData)} />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HMHWTHZ724" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HMHWTHZ724');
    </script>
    <script is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "x9c45gfnat");
    </script>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      import "../scripts/global-motion";
    </script>
  </body>
</html>
