---
import SectionHeading from "../primitives/SectionHeading.astro";
import hrdLogo from "../../../assets/source/logos/hrd/hrdf-training-and-claimable-icon-horizontal.png";

interface ServiceItem {
  eyebrow: string;
  title: string;
  description: string;
  points: readonly string[];
  href: string;
}

interface Props {
  eyebrow?: string;
  heading: string;
  description?: string;
  items: readonly ServiceItem[];
}

const { eyebrow, heading, description, items } = Astro.props;
const [primary, ...secondary] = items;
---

<section id="services" class="section-pad bg-[var(--color-bg)]">
  <div class="container-wide">
    <SectionHeading eyebrow={eyebrow} heading={heading} description={description} />

    <div class="services-grid mt-10">
      {
        primary && (
          <a class="service-card service-card--primary" href={primary.href}>
            <div>
              <p class="eyebrow">{primary.eyebrow}</p>
              <h3 class="display-md mt-4 text-balance">{primary.title}</h3>
              <p class="body-copy mt-4 max-w-2xl text-[var(--color-ink-muted)]">{primary.description}</p>
            </div>

            <div class="flex-1 flex items-center justify-center w-full min-h-[12rem] py-6">
              <img src={hrdLogo.src} width={hrdLogo.width} height={hrdLogo.height} alt="HRD Corp Claimable" class="w-full max-w-md h-auto object-contain opacity-90 mix-blend-multiply" loading="lazy" />
            </div>

            <ul class="service-pills" aria-label={`${primary.title} focus areas`}>
              {primary.points.map((point) => <li>{point}</li>)}
            </ul>
          </a>
        )
      }

      <div class="services-stack">
        {
          secondary.map((item) => (
            <a class="service-card" href={item.href}>
              <div>
                <p class="eyebrow">{item.eyebrow}</p>
                <h3 class="mt-4 text-xl font-semibold leading-tight">{item.title}</h3>
                <p class="body-copy mt-3 text-[var(--color-ink-muted)]">{item.description}</p>
              </div>

              <ul class="service-pills service-pills--compact" aria-label={`${item.title} focus areas`}>
                {item.points.map((point) => <li>{point}</li>)}
              </ul>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    gap: 1rem;
  }

  .services-stack {
    display: grid;
    gap: 1rem;
  }

  .service-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 24px;
    box-shadow: var(--shadow-sm);
    display: grid;
    gap: 2rem;
    min-height: 19rem;
    padding: clamp(1.35rem, 3vw, 2rem);
    transition:
      border-color 180ms var(--ease-standard),
      box-shadow 180ms var(--ease-standard),
      transform 180ms var(--ease-standard);
  }

  .service-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .service-card--primary {
    background:
      linear-gradient(135deg, rgb(124 58 237 / 0.12), transparent 34%),
      var(--color-surface);
    min-height: 32rem;
  }

  .service-pills {
    align-self: end;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .service-pills li {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.65rem 0.9rem;
  }

  .service-pills--compact li {
    font-size: 0.82rem;
    padding: 0.5rem 0.75rem;
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: minmax(0, 1.35fr) minmax(22rem, 0.65fr);
    }

    .services-stack {
      grid-template-rows: repeat(2, minmax(0, 1fr));
    }

    .service-card {
      min-height: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .service-card {
      transition: none;
    }

    .service-card:hover {
      transform: none;
    }
  }
</style>
