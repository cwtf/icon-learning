---
interface MediaPanel {
  eyebrow: string;
  title: string;
  items: readonly string[];
  footer: string;
}

interface Props {
  eyebrow: string;
  heading: string;
  body: string;
  points: readonly string[];
  media: MediaPanel;
  reverse?: boolean;
  number: string;
}

const { eyebrow, heading, body, points, media, reverse = false, number } = Astro.props;
---

<article class:list={["feature-stripe", reverse && "feature-stripe--reverse"]}>
  <div class="feature-media" aria-label={media.title}>
    <div class="feature-media-header">
      <span>{number}</span>
      <span>{media.eyebrow}</span>
    </div>
    <div class="feature-media-card">
      <div>
        <p class="body-sm font-semibold uppercase tracking-[0.08em] text-[var(--color-ink-dim)]">{media.footer}</p>
        <h3 class="mt-3 text-xl font-semibold leading-tight">{media.title}</h3>
      </div>
      <ul class="feature-media-list">
        {media.items.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>

  <div class="feature-copy">
    <p class="eyebrow">{eyebrow}</p>
    <h3 class="display-md mt-4 text-balance">{heading}</h3>
    <p class="body-copy mt-4 text-[var(--color-ink-muted)]">{body}</p>
    <ul class="mt-6 grid gap-3">
      {points.map((point) => <li>{point}</li>)}
    </ul>
  </div>
</article>

<style>
  .feature-stripe {
    align-items: center;
    display: grid;
    gap: clamp(1.5rem, 5vw, 5rem);
    grid-template-columns: minmax(0, 0.96fr) minmax(0, 1fr);
    padding-block: clamp(2rem, 5vw, 4rem);
  }

  .feature-stripe--reverse .feature-media {
    order: 2;
  }

  .feature-stripe--reverse .feature-copy {
    order: 1;
  }

  .feature-media {
    aspect-ratio: 4 / 3;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 16%, transparent), transparent 36%),
      linear-gradient(315deg, color-mix(in srgb, var(--color-ink) 8%, transparent), transparent 42%),
      var(--color-surface-muted);
    border: 1px solid var(--color-border);
    border-radius: 28px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 21rem;
    overflow: hidden;
    padding: clamp(1rem, 3vw, 1.5rem);
  }

  .feature-media-header {
    align-items: center;
    color: var(--color-ink-dim);
    display: flex;
    font-size: 0.75rem;
    font-weight: 700;
    justify-content: space-between;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .feature-media-card {
    background: color-mix(in srgb, var(--color-surface) 86%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    box-shadow: var(--shadow-sm);
    display: grid;
    gap: 1.5rem;
    padding: clamp(1rem, 3vw, 1.5rem);
  }

  .feature-media-list {
    display: grid;
    gap: 0.65rem;
  }

  .feature-media-list li {
    align-items: center;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-ink-muted);
    display: flex;
    font-size: 0.9rem;
    font-weight: 600;
    min-height: 2.75rem;
    padding: 0.55rem 0.85rem;
  }

  .feature-copy {
    max-width: 34rem;
  }

  .feature-copy li {
    border-top: 1px solid var(--color-border);
    color: var(--color-ink-muted);
    font-size: 0.95rem;
    line-height: 1.55;
    padding-top: 0.85rem;
  }

  @media (max-width: 767px) {
    .feature-stripe {
      grid-template-columns: 1fr;
      padding-block: 2.25rem;
    }

    .feature-stripe--reverse .feature-media,
    .feature-stripe--reverse .feature-copy {
      order: initial;
    }

    .feature-media {
      aspect-ratio: auto;
      min-height: 19rem;
    }
  }
</style>
