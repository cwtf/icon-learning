---
import Button from "../primitives/Button.astro";

interface Category {
  slug: string;
  title: string;
  summary: string;
  intro: string;
  topics: readonly string[];
  courses: readonly (string | { label: string; href: string })[];
}

interface Props {
  eyebrow?: string;
  heading: string;
  description?: string;
  browseAllCta: {
    label: string;
    href: string;
  };
  categories: readonly Category[];
}

const { eyebrow, heading, description, browseAllCta, categories } = Astro.props;

const courseHref = (category: Category, course: string) =>
  `/programs/${category.slug}/${course.toLowerCase().replace(/&/g, "and").replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "")}`;
const courseLabel = (course: Category["courses"][number]) => (typeof course === "string" ? course : course.label);
const previewHref = (category: Category, course: Category["courses"][number]) =>
  typeof course === "string" ? courseHref(category, course) : course.href;
---

<section id="categories" class="section-pad bg-[var(--color-surface-muted)]" data-courses-tabbed>
  <div class="container-wide">
    <div class="max-w-3xl" data-reveal>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2 class="display-lg mt-4 text-balance">{heading}</h2>
      {description && <p class="body-lg mt-5 max-w-2xl text-[var(--color-ink-muted)]">{description}</p>}
    </div>

    <div class="mt-12 grid gap-10 lg:grid-cols-[0.34fr_0.66fr] lg:items-start">
      <div class="course-labels" role="tablist" aria-label="Program categories">
        <div class="course-label-list">
          {
            categories.map((category) => (
              <button
                id={`tab-${category.slug}`}
                class="course-label"
                type="button"
                role="tab"
                data-course-label
                data-target={`category-${category.slug}`}
                aria-controls={`category-${category.slug}`}
                aria-current="false"
                aria-selected="false"
              >
                <span class="course-label-rule" aria-hidden="true"></span>
                <span class="display-md course-label-title">{category.title}</span>
                <span class="body-sm course-label-summary">{category.summary}</span>
              </button>
            ))
          }
        </div>
      </div>

      <div class="flex flex-col gap-8 lg:gap-0">
        {
          categories.map((category) => (
            <article
              id={`category-${category.slug}`}
              class="category-block"
              role="tabpanel"
              data-course-panel
              data-panel-slug={category.slug}
              aria-labelledby={`tab-${category.slug}`}
            >
              <div>
                <p class="eyebrow">Category preview</p>
                <h3 class="display-md mt-4">{category.title}</h3>
                <div class="category-topic-grid mt-5" aria-label={`${category.title} focus areas`}>
                  {category.topics.map((topic) => (
                    <span>{topic}</span>
                  ))}
                </div>
                <p class="body-copy mt-4 max-w-2xl text-[var(--color-ink-muted)]">{category.summary}</p>
                <p class="body-copy mt-4 max-w-2xl text-[var(--color-ink-muted)]">{category.intro}</p>
              </div>

              <div class="mt-6 grid gap-3 sm:grid-cols-2">
                {category.courses.map((course) => (
                  <a class="course-card" href={previewHref(category, course)}>
                    <span>{courseLabel(course)}</span>
                    <span aria-hidden="true">-&gt;</span>
                  </a>
                ))}
              </div>

              <div class="mt-7">
                <Button href={`/programs/${category.slug}`} variant="ghost">
                  Explore {category.title} -&gt;
                </Button>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div class="mt-12 flex justify-center">
      <Button href={browseAllCta.href} variant="outline">{browseAllCta.label} -&gt;</Button>
    </div>
  </div>
</section>

<script>
  import "./CoursesTabbed.client";
</script>

<style>
  .course-label-list {
    display: flex;
    gap: 0.75rem;
    margin-inline: calc(var(--page-gutter) * -1);
    overflow-x: auto;
    padding: 0 var(--page-gutter) 0.25rem;
    scroll-snap-type: x mandatory;
  }

  .course-label {
    align-items: flex-start;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    color: var(--color-ink-dim);
    cursor: pointer;
    display: grid;
    gap: 0.35rem 1rem;
    grid-template-columns: 0.25rem 1fr;
    min-width: min(18rem, 82vw);
    padding: 1rem;
    scroll-snap-align: start;
    text-align: left;
  }

  .course-label-rule {
    align-self: stretch;
    background: var(--color-accent);
    border-radius: 999px;
    opacity: 0;
    transition: opacity 250ms var(--ease-standard);
  }

  .course-label-title {
    color: inherit;
    transition: color 250ms var(--ease-standard);
  }

  .course-label-summary {
    color: var(--color-ink-muted);
    grid-column: 2;
    max-height: none;
    opacity: 1;
    overflow: hidden;
  }

  [data-courses-tabbed][data-enhanced] .course-label-summary {
    max-height: 0;
    opacity: 0;
    transform: translateY(4px);
    transition:
      max-height 250ms var(--ease-standard),
      opacity 250ms var(--ease-standard),
      transform 250ms var(--ease-standard);
  }

  .course-label.is-active {
    border-color: var(--color-border-strong);
    color: var(--color-ink);
    font-weight: 600;
  }

  .course-label.is-active .course-label-rule {
    opacity: 1;
  }

  .course-label.is-active .course-label-summary {
    max-height: 5rem;
    opacity: 1;
    transform: translateY(0);
  }

  .category-block {
    border: 1px solid var(--color-border);
    border-radius: 28px;
    box-shadow: var(--shadow-sm);
    min-height: auto;
    padding: clamp(1rem, 3vw, 2rem);
    scroll-margin-top: calc(var(--nav-height) + 1rem);
  }

  [data-courses-tabbed][data-enhanced] [data-course-panel][hidden] {
    display: none;
  }

  .category-topic-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-width: 42rem;
  }

  .category-topic-grid span {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-ink-muted);
    font-size: clamp(0.78rem, 1.5vw, 0.95rem);
    font-weight: 600;
    min-width: 0;
    padding: 0.65rem 0.85rem;
    text-align: center;
  }

  .course-card {
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    display: flex;
    font-size: 0.95rem;
    font-weight: 600;
    gap: 1rem;
    justify-content: space-between;
    min-height: 4.5rem;
    padding: 1rem;
    transition:
      border-color 180ms var(--ease-standard),
      box-shadow 180ms var(--ease-standard),
      transform 180ms var(--ease-standard);
  }

  .course-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  @media (min-width: 1024px) {
    .course-label-list {
      flex-direction: column;
      margin-inline: 0;
      overflow: visible;
      padding: 0;
      position: sticky;
      top: calc(var(--nav-height) + 4rem);
    }

    .course-label {
      background: transparent;
      border-color: transparent;
      border-radius: 0;
      min-width: 0;
      padding: 0.85rem 0 0.85rem 0.25rem;
      width: 100%;
    }

    .course-label.is-active {
      border-color: transparent;
    }

    .category-block {
      border: 0;
      border-radius: 0;
      box-shadow: none;
      padding: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-courses-tabbed][data-enhanced] .course-label-summary,
    .course-label-rule,
    .course-label-title,
    .course-card {
      transition: none;
    }

    .course-card:hover {
      transform: none;
    }
  }
</style>
