---
import Button from "../primitives/Button.astro";

interface Category {
  slug: string;
  title: string;
  summary: string;
  intro: string;
  topics: readonly string[];
  courses: readonly (string | { label: string; href: string })[];
}

interface Props {
  eyebrow?: string;
  heading: string;
  description?: string;
  browseAllCta: {
    label: string;
    href: string;
  };
  categories: readonly Category[];
}

const { eyebrow, heading, description, browseAllCta, categories } = Astro.props;

const courseHref = (category: Category, course: string) =>
  `/programs/${category.slug}/${course.toLowerCase().replace(/&/g, "and").replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "")}`;
const courseLabel = (course: Category["courses"][number]) => (typeof course === "string" ? course : course.label);
const previewHref = (category: Category, course: Category["courses"][number]) =>
  typeof course === "string" ? courseHref(category, course) : course.href;
---

<section id="categories" class="section-pad bg-[var(--color-bg)] relative" style={`--category-count: ${categories.length}`} data-courses-tabbed>
  <div class="sticky-wrapper">
    <div class="container-wide">
    <div class="max-w-3xl" data-reveal>
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2 class="display-lg mt-3 text-balance">{heading}</h2>
      {description && <p class="body-lg mt-4 max-w-2xl text-[var(--color-ink-muted)]">{description}</p>}
    </div>

    <div class="mt-8 lg:mt-6 grid gap-10 lg:grid-cols-[0.34fr_0.66fr] lg:items-start">
      <div class="course-labels" role="tablist" aria-label="Program categories">
        <div class="course-label-list">
          {
            categories.map((category) => (
              <button
                id={`tab-${category.slug}`}
                class="course-label"
                type="button"
                role="tab"
                data-course-label
                data-target={`category-${category.slug}`}
                aria-controls={`category-${category.slug}`}
                aria-current="false"
                aria-selected="false"
              >
                <span class="course-label-rule" aria-hidden="true"></span>
                <span class="display-md course-label-title">{category.title}</span>
                <span class="body-sm course-label-summary">{category.summary}</span>
              </button>
            ))
          }
        </div>
      </div>

      <div class="course-panel-stage flex flex-col gap-8 lg:gap-0">
        {
          categories.map((category) => (
            <article
              id={`category-${category.slug}`}
              class="category-block"
              role="tabpanel"
              data-course-panel
              data-panel-slug={category.slug}
              aria-labelledby={`tab-${category.slug}`}
            >
              <div>
                <p class="eyebrow course-panel-item" style="--panel-item-delay: 0ms">Category preview</p>
                <h3 class="display-md course-panel-item mt-4" style="--panel-item-delay: 45ms">{category.title}</h3>
                <div class="category-topic-grid course-panel-item mt-5" style="--panel-item-delay: 90ms" aria-label={`${category.title} focus areas`}>
                  {category.topics.map((topic) => (
                    <span>{topic}</span>
                  ))}
                </div>
                <p class="body-copy course-panel-item mt-4 max-w-2xl text-[var(--color-ink-muted)]" style="--panel-item-delay: 135ms">{category.summary}</p>
                <p class="body-copy course-panel-item mt-4 max-w-2xl text-[var(--color-ink-muted)]" style="--panel-item-delay: 180ms">{category.intro}</p>
              </div>

              <div class="course-panel-item mt-6 grid gap-3 sm:grid-cols-2 lg:mt-4" style="--panel-item-delay: 225ms">
                {category.courses.map((course) => (
                  <a class="course-card" href={previewHref(category, course)}>
                    <span>{courseLabel(course)}</span>
                    <span aria-hidden="true">-&gt;</span>
                  </a>
                ))}
              </div>

              <div class="course-panel-item mt-7 lg:mt-5" style="--panel-item-delay: 270ms">
                <Button href={`/programs/${category.slug}`} variant="ghost">
                  Explore {category.title} -&gt;
                </Button>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <div class="flex justify-center">
      <Button href={browseAllCta.href} variant="outline">{browseAllCta.label} -&gt;</Button>
    </div>
  </div>
  </div>
</section>

<script>
  import "./CoursesTabbed.client";
</script>

<style>
  .course-label-list {
    display: flex;
    gap: 0.75rem;
    margin-inline: calc(var(--page-gutter) * -1);
    overflow-x: auto;
    padding: 0 var(--page-gutter) 0.25rem;
    scroll-snap-type: x mandatory;
  }

  .course-label {
    align-items: flex-start;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    color: var(--color-ink-dim);
    cursor: pointer;
    display: grid;
    gap: 0.35rem 1rem;
    grid-template-columns: 0.25rem 1fr;
    min-width: min(18rem, 82vw);
    padding: 1rem;
    scroll-snap-align: start;
    text-align: left;
    transition:
      background-color 260ms var(--ease-standard),
      border-color 260ms var(--ease-standard),
      color 260ms var(--ease-standard),
      transform 260ms var(--ease-standard);
  }

  .course-label-rule {
    align-self: stretch;
    background: var(--color-accent);
    border-radius: 999px;
    opacity: 0;
    transition: opacity 250ms var(--ease-standard);
  }

  .course-label-title {
    color: inherit;
    transition: color 250ms var(--ease-standard);
  }

  .course-label-summary {
    color: var(--color-ink-muted);
    grid-column: 2;
    max-height: none;
    opacity: 1;
    overflow: hidden;
  }

  [data-courses-tabbed][data-enhanced] .course-label-summary {
    max-height: 0;
    opacity: 0;
    transform: translateY(4px);
    transition:
      max-height 250ms var(--ease-standard),
      opacity 250ms var(--ease-standard),
      transform 250ms var(--ease-standard);
  }

  .course-label.is-active {
    border-color: var(--color-border-strong);
    color: var(--color-ink);
    font-weight: 600;
  }

  .course-label.is-active .course-label-rule {
    opacity: 1;
  }

  .course-label.is-active .course-label-summary {
    max-height: 5rem;
    opacity: 1;
    transform: translateY(0);
  }

  .category-block {
    border: 1px solid var(--color-border);
    border-radius: 28px;
    box-shadow: var(--shadow-sm);
    min-height: auto;
    padding: clamp(1rem, 3vw, 2rem);
    scroll-margin-top: calc(var(--nav-height) + 1rem);
  }

  [data-courses-tabbed][data-enhanced] [data-course-panel][hidden] {
    display: none;
  }

  [data-courses-tabbed][data-enhanced] .category-block {
    opacity: 0;
    transform: translateY(14px);
  }

  [data-courses-tabbed][data-enhanced] .category-block.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  [data-courses-tabbed][data-enhanced] .category-block.is-exiting {
    opacity: 0;
    transform: translateY(-10px);
  }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  [data-courses-tabbed][data-enhanced] .course-panel-item {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 420ms var(--ease-enter),
      transform 420ms var(--ease-enter);
    transition-delay: var(--panel-item-delay, 0ms);
  }

  [data-courses-tabbed][data-enhanced] .category-block.is-active .course-panel-item {
    opacity: 1;
    transform: translateY(0);
  }

  [data-courses-tabbed][data-enhanced] .category-block.is-exiting .course-panel-item {
    opacity: 0;
    transform: translateY(-6px);
    transition-delay: 0ms;
  }

  .category-topic-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-width: 42rem;
  }

  .category-topic-grid span {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-ink-muted);
    font-size: clamp(0.78rem, 1.5vw, 0.95rem);
    font-weight: 600;
    min-width: 0;
    padding: 0.65rem 0.85rem;
    text-align: center;
  }

  .course-card {
    align-items: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    display: flex;
    font-size: 0.95rem;
    font-weight: 600;
    gap: 1rem;
    justify-content: space-between;
    min-height: 4.5rem;
    padding: 1rem;
    transition:
      border-color 180ms var(--ease-standard),
      box-shadow 180ms var(--ease-standard),
      transform 180ms var(--ease-standard);
  }

  .course-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  @media (min-width: 1024px) {
    [data-courses-tabbed][data-enhanced] {
      padding-block: 0;
      height: calc(100vh + (100vh * (var(--category-count) - 1) * 0.75));
    }

    [data-courses-tabbed][data-enhanced] .sticky-wrapper {
      position: sticky;
      top: 0;
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      overflow: hidden;
    }

    .course-label-list {
      flex-direction: column;
      margin-inline: 0;
      overflow: visible;
      padding: 0;
      position: relative;
    }

    [data-courses-tabbed][data-enhanced] .course-label-list::before {
      background: var(--color-accent);
      border-radius: 999px;
      content: "";
      height: var(--active-height, 3rem);
      left: 0;
      position: absolute;
      top: 0;
      transform: translateY(var(--active-y, 0px));
      transition:
        height 180ms var(--ease-standard),
        transform 180ms var(--ease-standard);
      width: 0.25rem;
      z-index: 0;
    }

    .course-label {
      --label-activity: 0;
      --label-shift: 0;
      background: transparent;
      border-color: transparent;
      border-radius: 0;
      opacity: calc(0.56 + (var(--label-activity) * 0.44));
      min-width: 0;
      padding: 0.85rem 0 0.85rem 0.25rem;
      position: relative;
      transform: translateX(calc(var(--label-shift) * 0.35rem));
      width: 100%;
      z-index: 1;
    }

    .course-label::before {
      background: color-mix(in srgb, var(--color-accent-soft), transparent 42%);
      border-radius: 14px;
      content: "";
      inset: 0.2rem -0.85rem 0.2rem -0.55rem;
      opacity: calc(var(--label-activity) * 0.72);
      position: absolute;
      transform: scaleX(calc(0.96 + (var(--label-activity) * 0.04)));
      transform-origin: left center;
      transition:
        opacity 260ms var(--ease-standard),
        transform 260ms var(--ease-standard);
      z-index: -1;
    }

    .course-label-title {
      opacity: calc(0.82 + (var(--label-activity) * 0.18));
    }

    .course-label.is-active {
      border-color: transparent;
    }

    .course-label.is-active .course-label-rule,
    .course-label-rule {
      opacity: 0;
    }

    .category-block {
      border: 0;
      border-radius: 0;
      box-shadow: none;
      padding: 0;
    }

    [data-courses-tabbed][data-enhanced] .course-panel-stage {
      min-height: clamp(28rem, 56vh, 34rem);
      position: relative;
    }

    [data-courses-tabbed][data-enhanced] .category-block {
      inset: 0;
      pointer-events: none;
      position: absolute;
      transition:
        opacity 460ms var(--ease-enter),
        transform 460ms var(--ease-enter);
      width: 100%;
      will-change: opacity, transform;
    }

    [data-courses-tabbed][data-enhanced] .category-block.is-active {
      pointer-events: auto;
      z-index: 2;
    }

    [data-courses-tabbed][data-enhanced] .category-block.is-exiting {
      z-index: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-courses-tabbed][data-enhanced] .category-block,
    [data-courses-tabbed][data-enhanced] .course-panel-item,
    [data-courses-tabbed][data-enhanced] .course-label-summary,
    .course-label-rule,
    .course-label-title,
    .course-card,
    .course-label {
      transition: none;
    }

    [data-courses-tabbed][data-enhanced] .category-block,
    [data-courses-tabbed][data-enhanced] .category-block.is-active,
    [data-courses-tabbed][data-enhanced] .category-block.is-exiting,
    [data-courses-tabbed][data-enhanced] .course-panel-item {
      opacity: 1;
      transform: none;
    }

    .course-card:hover {
      transform: none;
    }
  }
</style>
