---
import Button from "../primitives/Button.astro";
import BrandLogo from "../primitives/BrandLogo.astro";
import { navigationItems } from "../../content/navigation";
import { site } from "../../content/site";
---

<div id="nav-sentinel" class="absolute top-0 h-px w-px" aria-hidden="true"></div>
<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-[background,border-color,backdrop-filter] duration-200 ease-[var(--ease-standard)]"
>
  <nav class="container-wide flex h-[var(--nav-height)] items-center justify-between gap-6" aria-label="Primary navigation">
    <a class="flex shrink-0 items-center" href="/" aria-label={`${site.name} home`}>
      <BrandLogo />
    </a>

    <div class="hidden items-center gap-8 lg:flex">
      {
        navigationItems.map((item) => (
          <div class="nav-menu-item relative">
            <a class="body-sm relative text-[var(--color-ink-muted)] transition-colors after:absolute after:-bottom-1.5 after:left-0 after:h-px after:w-0 after:bg-[var(--color-ink)] after:transition-[width] after:duration-200 hover:text-[var(--color-ink)] hover:after:w-full" href={item.href}>
              {item.label}
            </a>
            {"children" in item && item.children?.length ? (
              <div class="nav-dropdown absolute left-1/2 top-full min-w-48 -translate-x-1/2 pt-4">
                <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-2 shadow-[var(--shadow-md)]">
                  {item.children.map((child) => (
                    <a class="block rounded-xl px-3 py-2.5 text-sm font-medium text-[var(--color-ink-muted)] transition-colors hover:bg-[var(--color-surface-muted)] hover:text-[var(--color-ink)]" href={child.href}>
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            ) : null}
          </div>
        ))
      }
    </div>

    <div class="flex shrink-0 items-center gap-3">
      <button
        class="theme-toggle grid h-11 w-11 cursor-pointer place-items-center rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink)] transition-colors hover:border-[var(--color-border-strong)]"
        type="button"
        data-theme-toggle
        aria-label="Toggle dark mode"
        aria-pressed="false"
        hidden
      >
        <svg class="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <svg class="theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
      </button>

      <div class="hidden lg:block">
        <Button href="/contact" variant="filled-ink">Request training</Button>
      </div>

      <details class="group relative lg:hidden">
      <summary class="grid h-11 w-11 cursor-pointer list-none place-items-center rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-ink)] marker:hidden" aria-label="Open menu">
        <span class="flex w-5 flex-col gap-1.5">
          <span class="h-0.5 rounded-full bg-current"></span>
          <span class="h-0.5 rounded-full bg-current"></span>
        </span>
      </summary>
      <div class="absolute right-0 top-14 w-[min(20rem,calc(100vw-2rem))] rounded-[20px] border border-[var(--color-border)] bg-[var(--color-surface)] p-4 shadow-[var(--shadow-md)]">
        <div class="flex flex-col gap-1">
          {
            navigationItems.map((item) => (
              <>
                <a class="rounded-xl px-3 py-3 text-sm font-medium text-[var(--color-ink-muted)] hover:bg-[var(--color-surface-muted)] hover:text-[var(--color-ink)]" href={item.href}>
                  {item.label}
                </a>
                {"children" in item && item.children?.length
                  ? item.children.map((child) => (
                      <a class="rounded-xl px-6 py-2.5 text-sm font-medium text-[var(--color-ink-muted)] hover:bg-[var(--color-surface-muted)] hover:text-[var(--color-ink)]" href={child.href}>
                        {child.label}
                      </a>
                    ))
                  : null}
              </>
            ))
          }
        </div>
        <Button class="mt-4 w-full" href="/contact" variant="filled-ink">Request training</Button>
      </div>
      </details>
    </div>
  </nav>
</header>

<script>
  const nav = document.querySelector("#site-nav");
  const sentinel = document.querySelector("#nav-sentinel");

  if (nav && sentinel) {
    const observer = new IntersectionObserver(([entry]) => {
      nav.toggleAttribute("data-scrolled", !entry.isIntersecting);
    });

    observer.observe(sentinel);
  }

  const root = document.documentElement;
  const systemDark = window.matchMedia("(prefers-color-scheme: dark)");
  const toggles = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");
  const themeColorMetas = document.querySelectorAll<HTMLMetaElement>('meta[name="theme-color"]');

  const effectiveTheme = () => root.dataset.theme ?? (systemDark.matches ? "dark" : "light");

  const syncThemeUi = () => {
    const dark = effectiveTheme() === "dark";
    for (const toggle of toggles) {
      toggle.setAttribute("aria-pressed", String(dark));
      toggle.setAttribute("aria-label", dark ? "Switch to light mode" : "Switch to dark mode");
    }
    for (const meta of themeColorMetas) {
      meta.content = dark ? "#121110" : "#fbfaf8";
    }
  };

  for (const toggle of toggles) {
    toggle.hidden = false;
    toggle.addEventListener("click", () => {
      const next = effectiveTheme() === "dark" ? "light" : "dark";
      // Choosing what the system already prefers returns to "follow system" instead of pinning.
      const followsSystem = (next === "dark") === systemDark.matches;
      if (followsSystem) {
        delete root.dataset.theme;
      } else {
        root.dataset.theme = next;
      }
      try {
        if (followsSystem) {
          localStorage.removeItem("theme");
        } else {
          localStorage.setItem("theme", next);
        }
      } catch {
        // Persistence is best-effort; the in-page toggle still works.
      }
      syncThemeUi();
    });
  }

  systemDark.addEventListener("change", syncThemeUi);
  syncThemeUi();
</script>

<style>
  #site-nav[data-scrolled] {
    background: color-mix(in srgb, var(--color-bg) 82%, transparent);
    backdrop-filter: blur(12px);
    border-color: var(--color-border);
  }

  .theme-toggle svg {
    grid-area: 1 / 1;
    transition: opacity 160ms var(--ease-standard);
  }

  .theme-icon-moon {
    opacity: calc(1 - var(--theme-dark));
  }

  .theme-icon-sun {
    opacity: var(--theme-dark);
  }

  .nav-dropdown {
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, -0.25rem);
    transition:
      opacity 160ms var(--ease-standard),
      transform 160ms var(--ease-standard);
  }

  .nav-menu-item:hover .nav-dropdown,
  .nav-menu-item:focus-within .nav-dropdown {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }
</style>
