---
import BaseLayout from "../layouts/BaseLayout.astro";
import ApproachSection from "../components/sections/ApproachSection.astro";
import BentoMasonry from "../components/sections/BentoMasonry.astro";
import CtaCloser from "../components/sections/CtaCloser.astro";
import CoursesTabbed from "../components/sections/CoursesTabbed.astro";
import FeaturedPublicTraining from "../components/sections/FeaturedPublicTraining.astro";
import Hero from "../components/sections/Hero.astro";
import ServicesBento from "../components/sections/ServicesBento.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import HomeClients from "../components/sections/HomeClients.astro";
import { coursesShowcase, ctaCloser, homeHero, proofBento, serviceSolutions, trainingApproach } from "../content/home";
import { featuredPublicTraining } from "../content/publicTraining";
const showFeaturedTraining = new Date() < new Date(featuredPublicTraining.sunsetAt);
import { approvedTestimonials, testimonialShowcase } from "../content/testimonials";
import workshopHeroImage from "../../assets/web/photos/ai-workshop-hero-03.jpg";
---

<BaseLayout>
  <Hero {...homeHero} backgroundImage={workshopHeroImage.src} />
  {showFeaturedTraining && <FeaturedPublicTraining training={featuredPublicTraining} />}
  <BentoMasonry {...proofBento} />
  <CoursesTabbed {...coursesShowcase} />
  <ServicesBento {...serviceSolutions} />
  <ApproachSection {...trainingApproach} />
  {approvedTestimonials.length > 0 && <Testimonials {...testimonialShowcase} items={approvedTestimonials} />}
  <HomeClients />
  <CtaCloser {...ctaCloser} />
</BaseLayout>
