---
import Button from "../components/primitives/Button.astro";
import ContactPanel from "../components/contact/ContactPanel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { contactPage } from "../content/contact";
import { featuredPublicTraining } from "../content/publicTraining";
import { site } from "../content/site";
import contactHeroImage from "../../assets/web/photos/ai-contact-hero-01.jpg";

const pageUrl = new URL("/contact", site.url).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: site.url,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Contact",
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: site.name,
    legalName: site.legalName,
    url: site.url,
    email: site.email,
    telephone: site.phone,
    foundingDate: site.foundingDate,
    identifier: site.registrationNumber,
    slogan: site.brandLine,
    address: {
      "@type": "PostalAddress",
      streetAddress: "No 1, Jalan Radin 5",
      postalCode: "57000",
      addressLocality: "Sri Petaling",
      addressRegion: "Kuala Lumpur",
      addressCountry: "MY",
    },
    openingHoursSpecification: [
      {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "09:00",
        closes: "18:00",
      },
    ],
    contactPoint: [
      {
        "@type": "ContactPoint",
        telephone: site.phone,
        email: site.email,
        contactType: "training inquiry",
        areaServed: "MY",
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: contactPage.faqs.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout title={contactPage.title} description={contactPage.description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <section
    class="contact-hero photo-hero"
    style={`--photo-hero-image: url("${contactHeroImage.src}"); --photo-hero-position: center right; --photo-hero-mobile-position: 64% center;`}
  >
    <div class="container-wide">
      <div class="contact-breadcrumb body-sm" data-reveal>
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>Contact</span>
      </div>

      <div class="mt-8 max-w-4xl">
        <p class="eyebrow" data-reveal>{contactPage.hero.eyebrow}</p>
        <h1 class="display-xl mt-4 text-balance" data-reveal>{contactPage.hero.heading}</h1>
        <p class="body-lg mt-5 max-w-3xl text-[var(--color-ink-muted)]" data-reveal>{contactPage.hero.sub}</p>
        <div class="mt-8 flex flex-wrap gap-3" data-reveal>
          {contactPage.quickActions.map((action, index) => (
            <Button href={action.href} variant={index === 0 ? "filled-ink" : "outline"}>{action.label}</Button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad pt-0">
    <div class="container-wide contact-layout">
      <div class="contact-form-shell" data-reveal>
        <p class="eyebrow">{contactPage.form.eyebrow}</p>
        <h2 class="display-md mt-4">{contactPage.form.heading}</h2>
        <p class="body-copy mt-4 max-w-3xl text-[var(--color-ink-muted)]">{contactPage.form.note}</p>

        <div class="registration-feature mt-6" aria-labelledby="registration-feature-heading">
          <div>
            <p class="eyebrow">{featuredPublicTraining.eyebrow}</p>
            <h3 id="registration-feature-heading">{featuredPublicTraining.shortTitle}</h3>
            <p>{featuredPublicTraining.scheduleLabel} / {featuredPublicTraining.mode}</p>
          </div>
          <Button href={featuredPublicTraining.registrationHref} variant="outline">Open registration form</Button>
        </div>

        <p class="contact-status body-sm mt-4" data-contact-status hidden aria-live="polite"></p>

        <form
          class="contact-form mt-7"
          action={site.emailHref}
          method="get"
          data-contact-form
          data-email={site.email}
        >
          <div class="contact-field-grid">
            <label>
              <span>Name</span>
              <input name="name" type="text" autocomplete="name" required />
            </label>

            <label>
              <span>Company</span>
              <input name="company" type="text" autocomplete="organization" />
            </label>

            <label>
              <span>Email</span>
              <input name="email" type="email" autocomplete="email" required />
            </label>

            <label>
              <span>Phone/WhatsApp</span>
              <input name="phone" type="tel" autocomplete="tel" />
            </label>
          </div>

          <label>
            <span>Training interest</span>
            <input name="training" type="text" placeholder="Course title, category, or team need" data-training-interest />
          </label>

          <div class="contact-field-grid">
            <label>
              <span>Team size</span>
              <select name="teamSize">
                <option value="">Select team size</option>
                {contactPage.form.teamSizes.map((item) => <option value={item}>{item}</option>)}
              </select>
            </label>

            <label>
              <span>Preferred format</span>
              <select name="format">
                <option value="">Select format</option>
                {contactPage.form.formats.map((item) => <option value={item}>{item}</option>)}
              </select>
            </label>
          </div>

          <label>
            <span>Message</span>
            <textarea name="message" rows="6" placeholder="Tell us the goal, preferred dates, location, and anything your team needs to consider."></textarea>
          </label>

          <div class="contact-submit-row">
            <Button type="submit" variant="filled-ink">Prepare email inquiry</Button>
            <p class="body-sm text-[var(--color-ink-muted)]">
              Prefer a quicker route? <a href={site.whatsappHref}>WhatsApp Icon Learning</a>.
            </p>
          </div>
        </form>
      </div>

      <div class="contact-panel-wrap">
        <ContactPanel heading="Contact cards" />
      </div>
    </div>
  </section>

  <section class="contact-faq section-pad">
    <div class="container-wide">
      <div class="contact-faq-heading" data-reveal>
        <p class="eyebrow">Buyer questions</p>
        <h2 class="display-md mt-4">Useful answers before you inquire</h2>
      </div>

      <div class="contact-faq-grid mt-6">
        {
          contactPage.faqs.map((item) => (
            <details class="contact-faq-item" data-reveal>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <script>
    import "../components/contact/ContactForm.client";
  </script>
</BaseLayout>

<style>
  .contact-hero {
    padding-block: calc(var(--nav-height) + 4.5rem) clamp(3rem, 7vw, 5.5rem);
  }

  .contact-breadcrumb {
    align-items: center;
    color: var(--color-ink-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .contact-breadcrumb a {
    color: var(--color-ink);
    font-weight: 700;
  }

  .contact-layout {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .contact-panel-wrap {
    order: -1;
  }

  .contact-form-shell {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-shadow: var(--shadow-sm);
    min-width: 0;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .contact-status {
    background: var(--color-accent-soft);
    border: 1px solid color-mix(in srgb, var(--color-accent), transparent 70%);
    border-radius: 8px;
    color: var(--color-ink);
    padding: 0.75rem 0.85rem;
  }

  .registration-feature {
    align-items: center;
    background: var(--color-accent-soft);
    border: 1px solid color-mix(in srgb, var(--color-accent), transparent 70%);
    border-radius: 8px;
    display: grid;
    gap: 1rem;
    padding: 1rem;
  }

  .registration-feature h3 {
    color: var(--color-ink);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.25;
    margin: 0.75rem 0 0;
  }

  .registration-feature p:not(.eyebrow) {
    color: var(--color-ink-muted);
    font-size: 0.9rem;
    line-height: 1.45;
    margin: 0.45rem 0 0;
  }

  .contact-form {
    display: grid;
    gap: 1rem;
  }

  .contact-field-grid {
    display: grid;
    gap: 1rem;
  }

  .contact-form label {
    display: grid;
    gap: 0.45rem;
  }

  .contact-form label span {
    color: var(--color-ink);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-ink);
    min-height: 3rem;
    padding: 0.8rem 0.95rem;
    width: 100%;
  }

  .contact-form textarea {
    min-height: 9rem;
    resize: vertical;
  }

  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: var(--color-ink-dim);
  }

  .contact-submit-row {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    margin-top: 0.5rem;
  }

  .contact-submit-row a {
    color: var(--color-accent);
    font-weight: 700;
  }

  .contact-faq {
    background: var(--color-surface-muted);
  }

  .contact-faq-heading {
    max-width: 44rem;
  }

  .contact-faq-grid {
    display: grid;
    gap: 0.75rem;
  }

  .contact-faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-shadow: var(--shadow-sm);
    padding: 1rem;
  }

  .contact-faq-item summary {
    color: var(--color-ink);
    cursor: pointer;
    font-weight: 700;
    line-height: 1.35;
  }

  .contact-faq-item p {
    color: var(--color-ink-muted);
    line-height: 1.6;
    margin: 0.75rem 0 0;
  }

  @media (min-width: 768px) {
    .contact-field-grid,
    .contact-faq-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 640px) {
    .registration-feature {
      grid-template-columns: minmax(0, 1fr) auto;
    }
  }

  @media (min-width: 1024px) {
    .contact-layout {
      align-items: start;
      grid-template-columns: minmax(0, 0.64fr) minmax(18rem, 0.36fr);
    }

    .contact-panel-wrap {
      order: initial;
    }
  }
</style>
