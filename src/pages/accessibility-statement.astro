---
import Button from "../components/primitives/Button.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { accessibilityPage } from "../content/accessibility";
import { site } from "../content/site";

const pageUrl = new URL("/accessibility-statement", site.url).toString();
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: site.url,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Accessibility Statement",
        item: pageUrl,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: accessibilityPage.title,
    description: accessibilityPage.description,
    url: pageUrl,
    dateModified: "2026-05-21",
    publisher: {
      "@type": "Organization",
      name: site.name,
      url: site.url,
    },
  },
];
---

<BaseLayout title={accessibilityPage.title} description={accessibilityPage.description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <section class="accessibility-hero">
    <div class="container-wide">
      <div class="accessibility-breadcrumb body-sm" data-reveal>
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>Accessibility</span>
      </div>

      <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,0.66fr)_minmax(18rem,0.34fr)] lg:items-end">
        <div>
          <p class="eyebrow" data-reveal>{accessibilityPage.hero.eyebrow}</p>
          <h1 class="display-xl mt-4 max-w-4xl text-balance" data-reveal>{accessibilityPage.hero.heading}</h1>
          <p class="body-lg mt-5 max-w-3xl text-[var(--color-ink-muted)]" data-reveal>{accessibilityPage.hero.sub}</p>
        </div>

        <div class="accessibility-status" data-reveal>
          <p class="eyebrow">Status</p>
          <strong>WCAG 2.2 AA target</strong>
          <span>Last updated {accessibilityPage.lastUpdated}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad pt-0">
    <div class="container-wide accessibility-layout">
      <article class="accessibility-main">
        <section class="accessibility-section" aria-labelledby="target-heading" data-reveal>
          <p class="eyebrow">{accessibilityPage.commitment.eyebrow}</p>
          <h2 id="target-heading" class="display-md mt-4">{accessibilityPage.commitment.heading}</h2>
          <p class="body-lg mt-5 max-w-3xl text-[var(--color-ink-muted)]">{accessibilityPage.commitment.body}</p>
        </section>

        <section class="accessibility-section" aria-labelledby="measures-heading" data-reveal>
          <p class="eyebrow">Measures</p>
          <h2 id="measures-heading" class="display-md mt-4">How the redesign supports access</h2>
          <ul class="accessibility-list mt-6">
            {accessibilityPage.measures.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="accessibility-section" aria-labelledby="limitations-heading" data-reveal>
          <p class="eyebrow">Known limitations</p>
          <h2 id="limitations-heading" class="display-md mt-4">What still needs attention</h2>
          <ul class="accessibility-list mt-6">
            {accessibilityPage.knownLimitations.map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="accessibility-section" aria-labelledby="review-heading" data-reveal>
          <p class="eyebrow">Review</p>
          <h2 id="review-heading" class="display-md mt-4">{accessibilityPage.review.heading}</h2>
          <p class="body-copy mt-4 max-w-3xl text-[var(--color-ink-muted)]">{accessibilityPage.review.body}</p>
        </section>
      </article>

      <aside class="accessibility-aside" aria-label="Accessibility feedback">
        <div class="accessibility-feedback" data-reveal>
          <p class="eyebrow">Feedback</p>
          <h2>{accessibilityPage.feedback.heading}</h2>
          <p>{accessibilityPage.feedback.body}</p>

          <dl class="accessibility-contacts">
            {
              accessibilityPage.feedback.contacts.map((contact) => (
                <div>
                  <dt>{contact.label}</dt>
                  <dd><a href={contact.href}>{contact.value}</a></dd>
                </div>
              ))
            }
          </dl>

          <div class="mt-6 grid gap-3">
            <Button href={site.emailHref} variant="filled-ink" class="w-full">Email accessibility feedback</Button>
            <Button href={site.whatsappHref} variant="outline" class="w-full">WhatsApp us</Button>
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .accessibility-hero {
    padding-block: calc(var(--nav-height) + 4.5rem) clamp(3rem, 7vw, 5.5rem);
  }

  .accessibility-breadcrumb {
    align-items: center;
    color: var(--color-ink-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .accessibility-breadcrumb a {
    color: var(--color-ink);
    font-weight: 700;
  }

  .accessibility-status {
    background:
      linear-gradient(135deg, rgb(124 58 237 / 0.12), transparent 38%),
      var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-shadow: var(--shadow-sm);
    min-height: 15rem;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .accessibility-status strong {
    color: var(--color-ink);
    display: block;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.05;
    margin-top: 3rem;
  }

  .accessibility-status span {
    color: var(--color-ink-muted);
    display: block;
    font-weight: 700;
    margin-top: 1rem;
  }

  .accessibility-layout {
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
  }

  .accessibility-main {
    display: grid;
    gap: clamp(2.5rem, 6vw, 4rem);
    min-width: 0;
  }

  .accessibility-section {
    border-top: 1px solid var(--color-border);
    padding-top: clamp(2rem, 5vw, 3rem);
  }

  .accessibility-section:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .accessibility-list {
    display: grid;
    gap: 0.85rem;
    list-style: none;
    margin-bottom: 0;
    max-width: 52rem;
    padding: 0;
  }

  .accessibility-list li {
    align-items: start;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-ink-muted);
    display: grid;
    gap: 0.85rem;
    grid-template-columns: 0.5rem 1fr;
    line-height: 1.6;
    padding: 1rem;
  }

  .accessibility-list li::before {
    background: var(--color-accent);
    border-radius: 999px;
    content: "";
    height: 0.5rem;
    margin-top: 0.55rem;
    width: 0.5rem;
  }

  .accessibility-aside {
    min-width: 0;
  }

  .accessibility-feedback {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-shadow: var(--shadow-sm);
    padding: 1.25rem;
  }

  .accessibility-feedback h2 {
    color: var(--color-ink);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.2;
    margin: 1rem 0 0;
  }

  .accessibility-feedback p {
    color: var(--color-ink-muted);
    line-height: 1.55;
    margin: 1rem 0 0;
  }

  .accessibility-contacts {
    border-top: 1px solid var(--color-border);
    display: grid;
    gap: 0;
    margin: 1.25rem 0 0;
  }

  .accessibility-contacts div {
    border-bottom: 1px solid var(--color-border);
    padding: 0.85rem 0;
  }

  .accessibility-contacts dt {
    color: var(--color-ink-muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .accessibility-contacts dd {
    color: var(--color-ink);
    font-weight: 700;
    margin: 0.25rem 0 0;
  }

  .accessibility-contacts a {
    color: var(--color-accent);
    overflow-wrap: anywhere;
  }

  @media (min-width: 1024px) {
    .accessibility-layout {
      align-items: start;
      grid-template-columns: minmax(0, 0.68fr) minmax(18rem, 0.32fr);
    }

    .accessibility-feedback {
      position: sticky;
      top: calc(var(--nav-height) + 2rem);
    }
  }
</style>
